{
  "name": "duzh",
  "version": "0.1.0",
  "description": "A graphical Roguelike in the browser, written in Typescript. fnord",
  "author": "jwbutler",
  "license": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/secondskullgames/duzh.git"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm run -r build",
    "clean": "pnpm run -r clean",
    "test": "pnpm run -r test",
    "lint": "pnpm run -r lint",
    "dev": "pnpm run --filter=main dev",
    "preview": "pnpm run --filter=main preview",
    "test:watch": "vitest --watch",
    "test:coverage": "pnpm run -r test:coverage",
    "electron": "cd electron && export npm_config_user_agent=npm && npm i && npm run make && npx electron ."
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3"
    }
  }
}
